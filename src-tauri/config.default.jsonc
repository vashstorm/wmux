{
  // IPC-only config for Tauri runtime. No HTTP server.
  // server.bind and auth.token are deprecated (ignored).
  "schemaVersion": 1,
  "path": ".",
  "server": {
    "bind": "127.0.0.1:7331"
  },
  "auth": {
    "token": ""
  },
  "tmux": {
    "path": "tmux"
  },
  "connections": [
    {
      "id": "local",
      "type": "local"
    }
  ]
}
