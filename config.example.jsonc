{
  // Increment when the config schema changes.
  "schemaVersion": 1,

  // Base runtime directory. Logs go to <path>/logs/, SQLite goes to <path>/data/.
  "path": ".",

  "server": {
    // Localhost binds can omit auth.token. Non-localhost binds must set it.
    "bind": "127.0.0.1:7331"
  },

  "auth": {
    // Leave empty only for localhost development.
    "token": "replace-with-a-random-token"
  },

  "tmux": {
    "path": "tmux"
  },

  "connections": [
    {
      "id": "local-dev",
      "type": "local"
    },
    {
      "id": "remote-prod",
      "type": "ssh",
      "host": "example.com",
      "port": 22,
      "user": "deploy",
      "privateKeyPath": "~/.ssh/id_ed25519",
      "knownHostsPath": "~/.ssh/known_hosts"
    }
  ],

  "ui": {
    "theme": "dark",
    "fontSize": 16,
    "terminalFontSize": 14,
    "terminalFontWeight": "normal"
  },
  "logs": {
    "level": "info",
    // Rotate each log file after it reaches this size in bytes. Set 0 to disable.
    "rotationSizeBytes": 10485760,
    // Delete rotated log files older than this many days. Set 0 to disable cleanup.
    "retentionDays": 14
  }
,
  "voice": {
    // Voice control via Qwen3.5-Omni realtime API.
    // When enabled, dashscopeApiKey is required.
    "enabled": false,
    // Obtain your API key from https://www.alibabacloud.com/help/en/dashscope/
    // This key is stored server-side only and is never sent to the frontend.
    "dashscopeApiKey": "YOUR_DASHSCOPE_API_KEY_HERE",
    // Safety switch: set true to block all microphone access regardless of other settings.
    "microphoneDisabled": false,
    // TTS voice name, e.g., Cherry. See DashScope docs for available voices.
    "voice": null,
    // Override built-in voice skills. Each entry can enable/disable a skill
    // or customize its system-prompt description.
    "skills": [
      // {
      //   "id": "session.switch",
      //   "enabled": true,
      //   "description": "Switch to a named tmux session."
      // }
    ],
    // Valid models: qwen3.5-omni-flash-realtime, qwen3.5-omni-plus-realtime
    "model": "qwen3.5-omni-flash-realtime",
    // DashScope realtime WebSocket endpoint. Do not change unless using a custom deployment.
    "endpoint": "wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime",
    // When true, the microphone stays active after each command (continuous listening mode).
    // Privacy note: audio is streamed to DashScope servers while listening.
    // If the browser blocks microphone access, check site permissions for the Wmux origin.
    "continuousListening": true,
    // Save raw audio recordings to disk. Disabled by default for privacy.
    "storeRawAudio": false,
    // Optional: path to a JSON-lines audit log file for voice interactions.
    // Secrets are automatically redacted from audit log entries.
    "auditLogPath": null,
    // Enable voice activity detection (VAD) to detect when the user starts/stops speaking.
    "vadEnabled": true,
    // VAD sensitivity threshold (0.0 - 1.0). Lower values detect quieter speech.
    "vadThreshold": 0.5
  }
}
